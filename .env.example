APP_ENV=dev
HTTP_ADDR=:8080
READ_TIMEOUT=10s
WRITE_TIMEOUT=30s
SHUTDOWN_TIMEOUT=10s

DATABASE_DSN=postgres://forge:forge@postgres:5432/forge?sslmode=disable
# Runtime bootstrap/break-glass admin token. Use it to open /manage/access on a fresh DB.
ADMIN_TOKEN=forge-admin-token
# Optional shared secret for encrypted /manage token sessions. Required for token login across multiple replicas unless OIDC_COOKIE_SECRET or ADMIN_TOKEN is stable.
MANAGE_SESSION_SECRET=
ARTIFACT_BACKEND=gcs
ARTIFACT_ENDPOINT=https://storage.googleapis.com
ARTIFACT_BUCKET=puppet-forge-artifacts
ARTIFACT_PROJECT=my-gcp-project
ARTIFACT_PREFIX=modules
ARTIFACT_REGION=us-east-1
ARTIFACT_ACCESS_KEY_ID=
ARTIFACT_SECRET_ACCESS_KEY=
ARTIFACT_PATH_STYLE=true
# Optional fallback. Leave empty to derive external URLs from Host/Forwarded/X-Forwarded-*.
PUBLIC_BASE_URL=
PUBLIC_MODULE_ACCESS=false
ACTIVE_RELEASE_TTL=720h
SECURITY_HSTS_ENABLED=false
WEB_AUTH_MODE=none
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Optional. Leave empty to derive from the current request URL and append /auth/callback.
OIDC_REDIRECT_URL=
# Optional. Auto-discovered from OIDC end_session_endpoint when provider exposes it.
OIDC_LOGOUT_URL=
OIDC_COOKIE_SECRET=
UPSTREAM_URL=https://forgeapi.puppetlabs.com
UPSTREAM_PROXY_JSON_CACHE_TTL=5m
UPSTREAM_PROXY_JSON_STALE_TTL=1h
FORGE_CACHE_MAX_BODY_BYTES=1048576
MODULE_UPLOAD_MAX_BYTES=134217728
UPSTREAM_ARTIFACT_MAX_BYTES=134217728
UPSTREAM_SYNC_INTERVAL=0s
UPSTREAM_SYNC_LIMIT=1000
METRICS_MODULE_LIMIT=10000
